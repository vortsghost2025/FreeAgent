const DRY_RUN = !security.isLive; // Use security guard's isLive

// Router Addresses
const UNISWAP_V2_ROUTER = 'REDACTED_ADDRESS';
const UNISWAP_V3_ROUTER = 'REDACTED_ADDRESS';

// ABI Definitions
const V2_ROUTER_ABI = [
  'function swapExactTokensForTokens(uint amountIn, uint amountOutMin, address[] calldata path, address to, uint deadline) external returns (uint[] memory amounts)',
];

const V3_ROUTER_ABI = [
  'function exactInput((address tokenIn, uint24 fee, address recipient, uint256 deadline, uint256 amountIn, uint256 amountOutMinimum, uint160 sqrtPriceLimitX96, uint160 sqrtPriceLimitX96)) external payable returns (uint256 amountOut)',
  'function exactInput(bytes path, address recipient, uint256 deadline, uint256 amountIn, uint256 amountOutMinimum) external payable returns (uint256 amountOut)',
];

// ERC20 ABI (for approvals)
const ERC20_ABI = [
  'function approve(address spender, uint256 amount) external returns (bool)',
];

// ============================================================
// Token Helper Functions
// ============================================================

// Known token addresses to symbols
const KNOWN_TOKENS = {
  'REDACTED_ADDRESS': 'WETH',
  'REDACTED_ADDRESS': 'USDC',
  'REDACTED_ADDRESS': 'DAI',
  'REDACTED_ADDRESS': 'WBTC',
  'REDACTED_ADDRESS': 'AAVE',
  'REDACTED_ADDRESS': 'UNI',
};

function getTokenSymbol(address) {
  return KNOWN_TOKENS[address.toLowerCase()] || address.slice(0, 6) + '...';
}
/**
 * Structure of arbitrage opportunity from watcher
 * {
 *   route: ['0x...', '0x...', '0x...'],  // Full path including start/end token
 *   routeType: '2-hop' | '3-hop',              // Number of hops
 *   dexes: ['Uniswap V2', 'Sushiswap'],         // DEXes used
 *   amountIn: BigInt,                          // Input amount (in wei)
 *   expectedProfitUsd: number,                  // Expected profit in USD
 *   tokenInSymbol: string,                      // Token symbol
 *   tokenInDecimals: number                    // Token decimals
 *   gasPrice: BigInt                          // Current gas price
 *   timestamp: number                          // When opportunity was detected
 * }
 */

// ============================================================
// Calldata Builder Functions
// ============================================================

/**
 * Build Uniswap V2 swap calldata
 */
function buildV2SwapCalldata(path, amountIn, amountOutMin, to, deadline) {
  const iface = new ethers.Interface(V2_ROUTER_ABI);
  const calldata = iface.encodeFunctionData('swapExactTokensForTokens', [
    amountIn,
    amountOutMin,
    path,
    to,
    deadline
  ]);

  return {
    calldata,
    routerAddress: UNISWAP_V2_ROUTER,
    functionName: 'swapExactTokensForTokens'
  };
}

/**
 * Build Uniswap V3 swap calldata (exactInput)
 */
function buildV3SwapCalldata(path, amountIn, amountOutMin, recipient, deadline, fee = 3000) {
  const iface = new ethers.Interface(V3_ROUTER_ABI);

  if (path.length === 2) {
    // Single hop
    const calldata = iface.encodeFunctionData('exactInput', [
      path,
      recipient,
      deadline,
      amountIn,
      amountOutMinimum
    ]);

    return {
      calldata,
      routerAddress: UNISWAP_V3_ROUTER,
      functionName: 'exactInput'
    };
  } else {
    // Multi-hop - V3 uses packed path
    const calldata = iface.encodeFunctionData('exactInput', [
      path,
      recipient,
      deadline,
      amountIn,
      amountOutMinimum
    ]);

    return {
      calldata,
      routerAddress: UNISWAP_V3_ROUTER,
      functionName: 'exactInput',
      isMultiHop: true
    };
  }
}

// ============================================================
// Route Simulator
// ============================================================

/**
 * Simulate an arbitrage route across multiple hops
 * Uses eth_call to dry-run the entire transaction
 */
async function simulateRoute(provider, route, amountIn, executorAddress) {
  console.log('\n🔄 Simulating arbitrage route...');

  const simulationResults = [];

  let currentAmount = amountIn;
  const routeDetails = [];

  for (let i = 0; i < route.hops.length; i++) {
    const hop = route.hops[i];

    console.log(`\n   📍 Hop ${i + 1}/${route.hops.length}`);
    console.log(`      DEX: ${hop.dex}`);
    console.log(`      Tokens: ${hop.tokenInSymbol} → ${hop.tokenOutSymbol}`);
    console.log(`      Amount: ${ethers.formatUnits(currentAmount, hop.tokenInDecimals)} ${hop.tokenInSymbol}`);

    // Build calldata for this hop
    let calldata;
    let routerAddress;

    if (hop.dex === 'Uniswap V2') {
      ({ calldata, routerAddress } = buildV2SwapCalldata(
        [hop.tokenInAddress, hop.tokenOutAddress],
        currentAmount,
        0, // No slippage for simulation
        executorAddress,
        Math.floor(Date.now() / 1000) + 3600
      ));
    } else if (hop.dex === 'Uniswap V3') {
      ({ calldata, routerAddress } = buildV3SwapCalldata(
        [hop.tokenInAddress, hop.tokenOutAddress],
        currentAmount,
        0, // No slippage for simulation
        executorAddress,
        Math.floor(Date.now() / 1000) + 3600,
        hop.fee // Use fee tier from hop
      ));
    } else {
      console.log(`   ⚠️  Unsupported DEX: ${hop.dex}`);
      simulationResults.push({
        hop: i + 1,
        success: false,
        error: `Unsupported DEX: ${hop.dex}`
      });
      return simulationResults;
    }

    // Simulate the hop using eth_call
    console.log(`      🧪 Simulating swap on ${hop.dex}...`);

    try {
      const result = await provider.call({
        to: routerAddress,
        data: calldata,
        from: executorAddress
      });

      // Parse the result to get actual output amount
      let outputAmount;
      if (hop.dex === 'Uniswap V2') {
        const iface = new ethers.Interface(V2_ROUTER_ABI);
        const decoded = iface.decodeFunctionResult('swapExactTokensForTokens', result);
        outputAmount = decoded.amounts[decoded.amounts.length - 1]; // Final output
      } else if (hop.dex === 'Uniswap V3') {
        const iface = new ethers.Interface(V3_ROUTER_ABI);
        const decoded = iface.decodeFunctionResult('exactInput', result);
        outputAmount = decoded[0]; // exactInput returns amountOut directly
      }

      const outputFormatted = ethers.formatUnits(outputAmount, hop.tokenOutDecimals);
      console.log(`      ✅ Simulated output: ${outputFormatted} ${hop.tokenOutSymbol}`);

      simulationResults.push({
        hop: i + 1,
        success: true,
        dex: hop.dex,
        tokenIn: hop.tokenInSymbol,
        tokenOut: hop.tokenOutSymbol,
        amountIn: currentAmount,
        amountOut: outputAmount,
        calldata: calldata,
        routerAddress: routerAddress
      });

      // Update current amount for next hop
      currentAmount = outputAmount;

    } catch (error) {
      console.log(`      ❌ Simulation failed: ${error.message}`);
      simulationResults.push({
        hop: i + 1,
        success: false,
        error: error.message
      });
      return simulationResults;
    }
  }

  console.log(`\n   📊 Final Output Amount: ${ethers.formatUnits(currentAmount, route.hops[route.hops.length - 1].tokenOutDecimals)} ${route.hops[route.hops.length - 1].tokenOutSymbol}`);

  return {
    success: simulationResults.every(r => r.success),
    finalAmount: currentAmount,
    initialAmount: amountIn,
    profit: currentAmount - amountIn,
    simulationResults
  };
}

// ============================================================
// Profit Calculator
// ============================================================

/**
 * Calculate net profit after gas costs
 */
async function calculateNetProfit(provider, finalAmount, initialAmount, routeType, gasPrice) {
  // Estimate gas for the entire route
  const gasEstimate = routeType === '2-hop' ? 250000n : 400000n;
  const gasCostWei = gasPrice * gasEstimate;
  const gasCostEth = Number(ethers.formatEther(gasCostWei));
  const gasCostUsd = gasCostEth * 2000; // ETH price $2000

  // Calculate profit
  const initialEth = Number(ethers.formatEther(initialAmount));
  const finalEth = Number(ethers.formatEther(finalAmount));
  const profitEth = finalEth - initialEth;
  const profitUsd = profitEth * 2000;

  return {
    gasCostWei,
    gasCostEth,
    gasCostUsd,
    profitEth,
    profitUsd,
    netProfit: profitUsd - gasCostUsd
  };
}

// ============================================================
// Main Executor Class
// ============================================================

class ArbitrageExecutor {
  constructor(provider, wallet) {
    this.provider = provider;
    this.wallet = wallet;
    this.executorAddress = wallet.address;
  }

  /**
   * Execute arbitrage based on opportunity
   */
  async execute(opportunity) {
    console.log('\n' + '='.repeat(60));
    console.log('🚀 ARBITRAGE EXECUTOR');
    console.log('='.repeat(60) + '\n');

    console.log(`📊 Opportunity Details:`);
    console.log(`   Route: ${opportunity.route.join(' → ')}`);
    console.log(`   Type: ${opportunity.routeType}`);
    console.log(`   Input: ${ethers.formatUnits(opportunity.amountIn, opportunity.tokenInDecimals)} ${opportunity.tokenInSymbol}`);
    console.log(`   Expected Profit: $${opportunity.expectedProfitUsd.toFixed(2)}\n`);

    // Build hops from route - route has N tokens, we need N-1 swaps
    // Example: [WETH, USDC, WETH] = 2 swaps: WETH→USDC, USDC→WETH
    const numHops = opportunity.route.length - 1;
    const hops = [];

    for (let i = 0; i < numHops; i++) {
      const tokenIn = opportunity.route[i];
      const tokenOut = opportunity.route[i + 1];

      // Get token symbols - default to address if not available
      const tokenInSymbol = i === 0 ? opportunity.tokenInSymbol : getTokenSymbol(tokenIn);
      const tokenOutSymbol = i === numHops - 1 ? opportunity.tokenInSymbol : getTokenSymbol(tokenOut);

      // Get token decimals for this hop
      const tokenInDecimals = i === 0 ? opportunity.tokenInDecimals : 18; // Default to 18 if unknown

      hops.push({
        dex: opportunity.dexes[i % opportunity.dexes.length],
        tokenInAddress: tokenIn,
        tokenOutAddress: tokenOut,
        tokenInSymbol: tokenInSymbol,
        tokenOutSymbol: tokenOutSymbol,
        tokenInDecimals: tokenInDecimals,
        tokenOutDecimals: i === numHops - 1 ? opportunity.tokenInDecimals : 18,
        amountIn: opportunity.amountIn, // Will be updated after each hop
        fee: 3000 // Default fee (V3)
      });
    }

    console.log(`📍 Route Hops: ${hops.length}`);
    hops.forEach((hop, idx) => {
      console.log(`   ${idx + 1}. ${hop.dex}: ${hop.tokenInSymbol} → ${hop.tokenOutSymbol}`);
    });

    // ============================================================
    // Step 2: Simulate Route
    // ============================================================
    const { feeData } = await this.provider.getFeeData();
    const gasPrice = feeData.gasPrice;

    const simulation = await simulateRoute(this.provider, { hops }, opportunity.amountIn, this.executorAddress);

    if (!simulation.success) {
      console.log(`\n❌ Route simulation failed!`);
      simulation.simulationResults.forEach(r => {
        if (!r.success) {
          console.log(`   Hop ${r.hop}: ${r.error}`);
        }
      });
      return { shouldExecute: false, reason: 'Simulation failed' };
    }

    console.log(`\n✅ Route Simulation Successful!`);
    console.log(`   Initial: ${ethers.formatUnits(simulation.initialAmount, opportunity.tokenInDecimals)} ${opportunity.tokenInSymbol}`);
    console.log(`   Final:   ${ethers.formatUnits(simulation.finalAmount, opportunity.tokenInDecimals)} ${opportunity.tokenInSymbol}`);
    console.log(`   Profit:   ${ethers.formatUnits(simulation.profit, opportunity.tokenInDecimals)} ${opportunity.tokenInSymbol}`);

    const profitPercent = (Number(simulation.profit) / Number(opportunity.amountIn)) * 100;
    console.log(`   Profit %:  ${profitPercent.toFixed(4)}%\n`);

    // ============================================================
    // Step 3: Calculate Net Profit
    // ============================================================
    const profitData = await calculateNetProfit(
      this.provider,
      simulation.finalAmount,
      simulation.initialAmount,
      opportunity.routeType,
      gasPrice
    );

    console.log(`\n💰 Profit Analysis:`);
    console.log(`   Gross Profit: $${profitData.profitUsd.toFixed(4)}`);
    console.log(`   Gas Cost:    $${profitData.gasCostUsd.toFixed(4)}`);
    console.log(`   Net Profit:  $${profitData.netProfit.toFixed(4)}\n`);

    // ============================================================
    // Step 4: Make Decision
    // ============================================================
    const MIN_NET_PROFIT_USD = 1.0; // Minimum $1.00 net profit

    const shouldExecute = profitData.netProfit >= MIN_NET_PROFIT_USD && !DRY_RUN;

    console.log(`\n🎯 Decision:`);
    console.log(`   Net Profit: $${profitData.netProfit.toFixed(4)}`);
    console.log(`   Minimum:    $${MIN_NET_PROFIT_USD.toFixed(2)}`);
    console.log(`   Decision:    ${shouldExecute ? '✅ GO' : '❌ NO-GO'}`);
    console.log(`   Mode:       ${DRY_RUN ? '🔒 DRY_RUN' : '⚡ LIVE'}\n`);

    // ============================================================
    // Step 5: Execute (if approved)
    // ============================================================
    if (shouldExecute) {
      console.log(`\n⚡ EXECUTING ARBITRAGE...`);

      // Approve tokens if needed (simplified - assumes already approved)
      console.log(`   Tokens are approved, proceeding with execution...`);

      // Build final transaction
      const finalHop = simulation.simulationResults[simulation.simulationResults.length - 1];
      const calldata = finalHop.calldata;
      const routerAddress = finalHop.routerAddress;

      if (!calldata) {
        console.log(`   ⚠️ No calldata available for final hop`);
        return { shouldExecute: false, reason: 'No calldata' };
      }

      // Send transaction
      try {
        const gasEstimate = opportunity.routeType === '2-hop' ? 250000n : 400000n;

        const tx = await this.wallet.sendTransaction({
          to: routerAddress,
          data: calldata,
          gasLimit: gasEstimate
        });

        console.log(`\n✅ Transaction Sent!`);
        console.log(`   Hash:  ${tx.hash}`);
        console.log(`   Waiting for confirmation...\n`);

        const receipt = await tx.wait();
        console.log(`✅ Confirmed in block ${receipt.blockNumber}\n`);
        console.log(`   Gas Used:  ${receipt.gasUsed.toString()}\n`);

        return {
          shouldExecute: true,
          executed: true,
          txHash: tx.hash,
          blockNumber: receipt.blockNumber,
          gasUsed: receipt.gasUsed,
          actualProfit: profitData.netProfit
        };
      } catch (error) {
        console.log(`\n❌ Execution failed: ${error.message}\n`);
        return {
          shouldExecute: true,
          executed: false,
          error: error.message
        };
      }
    } else {
      console.log(`\n🛑 SKIPPING EXECUTION - Net profit below minimum\n`);
      return {
        shouldExecute: false,
        reason: 'Net profit below minimum',
        executed: false
      };
    }
  }
}

