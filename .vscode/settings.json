{
  "files.associations": {
    "kilo-diagnostics-*.json": "plaintext"
  },
  "json.schemas": [],
  "json.format.enable": false,
  "window.newWindowDimensions": "inherit",
  "window.restoreWindows": "preserve",
  "window.openFilesInNewWindow": "default",
  "window.closeWhenEmpty": false,
  "workbench.startupEditor": "welcomePage",
  "extensions.autoUpdate": false,
  "remote.SSH.showLoginTerminal": true,
  "kilo-code.debug": true,
  "kilo-code.debugProxy.enabled": true,
  "kilo-code.debugProxy.tlsInsecure": true,
  "kilo-code.newTaskRequireTodos": true,
  "kilo-code.preventCompletionWithOpenTodos": true,
  "workbench.editor.enablePreview": false,
  "debug.allowMultipleSessions": true,
  "claudeCode.multiSession": true
}
