# Medical AI Federation - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# ELASTICSEARCH - Cloud Logging (Optional)
# =============================================================================

# Elasticsearch Cloud endpoint
# Get from: https://cloud.elastic.co
ELASTICSEARCH_URL=https://my-elasticsearch-project-dd509a.es.us-central1.gcp.elastic.cloud:443

# Elasticsearch API Key (generate from Kibana > Stack Management > API Keys)
# ELASTICSEARCH_API_KEY=your-api-key-here

# Elasticsearch index name for logs (default: cockpit-logs)
# ELASTICSEARCH_INDEX=cockpit-logs

# =============================================================================
# HYBRID INFERENCE MESH - Provider Configuration
# =============================================================================

# Kilo API Key - Cloud inference provider
# Get your key from: https://kilo.ai (or your Kilo provider)
# When set, Kilo will be enabled for complex tasks (auto-fix, triage, orchestration)
KILO_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbnYiOiJwcm9kdWN0aW9uIiwia2lsb1VzZXJJZCI6IjRhM2NlMjdkLWVkMjEtNGY3MC1hMTFhLWQ3NDA4MDkxZjRjMyIsImFwaVRva2VuUGVwcGVyIjpudWxsLCJ2ZXJzaW9uIjozLCJpYXQiOjE3NzE5MzE4MzUsImV4cCI6MTkyOTYxMTgzNX0.IZ7utyNGRcnxfXdjxztQvVHt4_A2xxSAmrXiaRYCE1Y

# Kilo API Endpoint (optional - defaults to https://api.kilo.ai/v1/chat/completions)
# KILO_ENDPOINT=https://api.kilo.ai/v1/chat/completions

# =============================================================================
# OLLAMA - Local Model Configuration
# =============================================================================

# Ollama endpoint (default: http://localhost:11434/api/generate)
# OLLAMA_ENDPOINT=http://localhost:11434/api/generate

# Default model for Ollama (default: llama3.1:8b)
# OLLAMA_MODEL=llama3.1:8b

# =============================================================================
# COCKPIT SERVER - Configuration
# =============================================================================

# Port for the cockpit server (default: 8889)
# COCKPIT_PORT=8889

# Host binding (default: 0.0.0.0 for all interfaces)
# COCKPIT_HOST=0.0.0.0

# =============================================================================
# OPTIONAL - Additional Providers (future use)
# =============================================================================

# OpenAI API Key (if using OpenAI fallback)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (if using Claude fallback)
# ANTHROPIC_API_KEY=sk-ant-...
