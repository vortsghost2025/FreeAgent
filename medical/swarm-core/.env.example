# Swarm-Core Configuration Template

# Core Settings
NODE_ENV=production
SWARM_VERSION=1.0.0

# Network Configuration
WS_PORT=8765
HTTP_PORT=3000
CONSensus_THRESHOLD=67

# Agent Configuration
DEFAULT_AGENT_COUNT=100
MAX_AGENT_COUNT=1000
AGENT_RESPONSE_TIMEOUT=5000

# Hackathon Specific (Override per submission)
HACKATHON_NAME=
HACKATHON_CATEGORY=
DEMO_REQUIREMENTS=

# Resource Providers
ALIBABA_CREDITS=70000000
AWS_CREDITS=100
GCP_CREDITS=300
DIGITALOCEAN_CREDITS=200

# API Keys (Use environment-specific values)
ALCHEMY_API_KEY=
INFURA_PROJECT_ID=
ETHERSCAN_API_KEY=

# Performance Settings
STRESS_TEST_AGENTS=1000
MEMORY_LIMIT_MB=2048
CPU_LIMIT=2

# Monitoring
TELEMETRY_ENABLED=true
LOG_LEVEL=info
METRICS_EXPORT_INTERVAL=30

# Safety Rails
MAX_CONCURRENT_OPERATIONS=50
ERROR_RETRY_ATTEMPTS=3
HEALTH_CHECK_INTERVAL=30