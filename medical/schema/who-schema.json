{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WHO Data Input Schema",
  "description": "Contract for WHO-formatted medical data inputs",
  "type": "object",
  "properties": {
    "caseId": { "type": "string" },
    "reportDate": { "type": "string", "format": "date-time" },
    "country": { "type": "string" },
    "source": {
      "type": "string",
      "enum": ["who-surveillance", "who-outbreak", "who-laboratory", "who-clinical"]
    },
    "symptoms": {
      "type": "object",
      "properties": {
        "list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "term": { "type": "string" },
              "severity": { "type": "string", "enum": ["mild", "moderate", "severe", "critical"] }
            }
          }
        }
      }
    },
    "laboratoryResults": {
      "type": "object",
      "properties": {
        "tests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "testCode": { "type": "string" },
              "testName": { "type": "string" },
              "result": { "type": "string" },
              "value": { "type": "number" },
              "unit": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "required": ["source"]
}
