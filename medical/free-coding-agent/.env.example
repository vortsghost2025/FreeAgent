# ============================================
# Free Coding Agent - Environment Variables
# ============================================
# Copy this file to .env and fill in your keys
# Most providers have FREE tiers!

# ============================================
# LOCAL PROVIDERS (No API key needed)
# ============================================
# Ollama must be running locally: https://ollama.com
# OLLAMA_ENABLED=true
# OLLAMA_HOST=localhost:11434

# LM Studio must be running locally
# LMSTUDIO_URL=http://localhost:1234/v1

# ============================================
# ANTHROPIC (Claude) - Recommended
# ============================================
# Get free API credits: https://console.anthropic.com/
# CLAUDE_API_KEY=sk-ant-api03-xxxxx

# ============================================
# GROQ - FREE (14,400 requests/day!)
# ============================================
# Sign up: https://console.groq.com/
# GROQ_API_KEY=gsk_xxxxx

# ============================================
# OPENROUTER - Many free models
# ============================================
# Sign up: https://openrouter.ai/
# OPENROUTER_API_KEY=sk-or-xxxxx

# ============================================
# OPENAI - Paid (GPT-4o mini is cheap)
# ============================================
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxx

# ============================================
# TOGETHER AI - Free credits available
# ============================================
# https://together.ai/
# TOGETHER_API_KEY=xxxxx

# ============================================
# CLOUDFLARE AI - 10k neurons/day free
# ============================================
# https://developers.cloudflare.com/workers-ai/
# CLOUDFLARE_ACCOUNT_ID=xxxxx
# CLOUDFLARE_AI_KEY=xxxxx

# ============================================
# HUGGINGFACE - Free inference
# ============================================
# https://huggingface.co/settings/inference-tokens
# HUGGINGFACE_API_KEY=hf_xxxxx

# ============================================
# KILO ENDPOINT
# ============================================
# KILO_API_KEY=xxxxx
# KILO_ENDPOINT=https://api.kilo.ai/v1/chat/completions
