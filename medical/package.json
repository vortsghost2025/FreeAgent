{
    "name": "gemini-live-agent-challenge",
    "version": "1.0.0",
    "type": "module",
    "description": "Multi-agent system for Gemini Live Agent Challenge - Adapted from battle-tested MEV swarm infrastructure",
    "main": "consensus-coordinator.js",
    "scripts": {
        "start": "node consensus-coordinator.js",
        "agent": "node decision-agent.js",
        "watcher": "node data-watcher.js",
        "stress-test": "node stress-tester.js",
        "dev": "concurrently \"npm run start\" \"npm run agent\" \"npm run watcher\"",
        "test": "node stress-tester.js 100 300000",
        "demo": "docker-compose up"
    },
    "dependencies": {
        "@flashbots/ethers-provider-bundle": "^1.0.0",
        "axios": "^1.6.7",
        "directory": "^0.1.0",
        "dotenv": "^16.6.1",
        "ethers": "^6.16.0",
        "express": "^4.18.2",
        "ws": "^8.16.0",
        "zeromq": "^6.5.0"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "keywords": [
        "multi-agent",
        "consensus",
        "gemini",
        "ai-agents",
        "distributed-systems",
        "hackathon"
    ],
    "author": "MEV Swarm Team",
    "license": "MIT",
    "engines": {
        "node": ">=16.0.0"
    }
}
